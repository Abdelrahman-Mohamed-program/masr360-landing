MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/m360?retryWrites=true&w=majority

# Comma-separated list of allowed CORS origins (the frontend URL)
CLIENT_ORIGIN=http://localhost:5173

